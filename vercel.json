{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(pb-[^/]+\\.(?:js|css))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/shippo-oauth-redirect", "destination": "/api/shippo-oauth-redirect" },
    { "source": "/shippo-oauth-redirect/", "destination": "/api/shippo-oauth-redirect" },
    { "source": "/privacy", "destination": "/privacy-policy.html" },
    { "source": "/terms", "destination": "/terms-of-service.html" },
    { "source": "/marketplace-terms", "destination": "/marketplace-seller-terms.html" },
    { "source": "/refund-policy", "destination": "/refund-buyer-protection.html" },
    { "source": "/acceptable-use", "destination": "/prohibited-items-acceptable-use.html" },
    { "source": "/delete-account", "destination": "/delete-account.html" }
  ],
  "crons": [
    {
      "path": "/api/keepalive",
      "schedule": "*/4 * * * *"
    },
    {
      "path": "/api/discord-bot?warm=1",
      "schedule": "*/4 * * * *"
    },
    {
      "path": "/api/discord-movers-cron",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/spike-alerts-cron",
      "schedule": "0 15 * * *"
    }
  ]
}
