<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- APNs environment for push notifications. Xcode's "Push Notifications"
	     capability manages this file and flips 'development' -> 'production'
	     automatically for App Store archive builds. If you add the capability
	     in Xcode (Signing & Capabilities -> + Capability -> Push Notifications),
	     it will pick up / recreate this file and wire CODE_SIGN_ENTITLEMENTS. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
